# ==============================================================================
# ANNUAIRECONGO Local Docker Deployment Environment Variables Template
# ==============================================================================
# Copy this file to a new file named '.env' in the same folder and customize values:
# cp .env.example .env
# Do NOT commit the '.env' file containing real secrets to source control.
# ==============================================================================

# Application Environment: 'Development' (shows Scalar/Swagger docs) or 'Production'
ASPNETCORE_ENVIRONMENT=Development

# SQL Server Database Configuration
# Warning: Password must meet SQL Server complexity requirements:
# Active directory integration / minimum 8 characters / UPPER / lower / digit / symbol
SQL_PASSWORD=YourStrong@Password1

# Grafana Admin User Security Credentials
GRAFANA_PASSWORD=YourStrongPwd
